  "exemplo_codigo_python_reportlab": {
    "descricao": "Exemplo de como sobrepor texto no PDF usando reportlab + pypdf",
    "codigo": [
      "from reportlab.pdfgen import canvas",
      "from reportlab.lib.pagesizes import A4",
      "from pypdf import PdfReader, PdfWriter",
      "import io",
      "",
      "ALTURA = 841.92",
      "",
      "def top_to_y(top, font_size=9):",
      "    return ALTURA - top - font_size",
      "",
      "packet = io.BytesIO()",
      "c = canvas.Canvas(packet, pagesize=(595.32, ALTURA))",
      "c.setFont('Helvetica', 9)",
      "",
      "# Exemplo: preencher nome completo",
      "c.drawString(19.6, top_to_y(142), 'JOÃO DA SILVA SOUZA')",
      "",
      "# Exemplo: marcar checkbox 'primeiro_emprego SIM'",
      "c.drawString(87.6, top_to_y(234), 'X')",
      "",
      "c.save()",
      "packet.seek(0)",
      "",
      "overlay = PdfReader(packet)",
      "original = PdfReader('ficha_cadastral.pdf')",
      "writer = PdfWriter()",
      "page = original.pages[0]",
      "page.merge_page(overlay.pages[0])",
      "writer.add_page(page)",
      "",
      "with open('ficha_preenchida.pdf', 'wb') as f:",
      "    writer.write(f)"
    ]
  }
